# Copie este arquivo para ".env" e preencha com seus dados reais.
# NUNCA suba o .env para o GitHub.

PORT=3000

# ---- Credenciais AmploPay ----
# Painel AmploPay > Credenciais > "Criar/Consultar transacoes"
AMPLOPAY_CLIENT_ID=
AMPLOPAY_CLIENT_SECRET=

# ---- Endpoints AmploPay ----
# CONFIRA ESSES VALORES NA DOCUMENTACAO DA AMPLOPAY E AJUSTE SE PRECISAR.
AMPLOPAY_BASE_URL=https://api.amplopay.com
AMPLOPAY_CREATE_PATH=/v1/transactions
AMPLOPAY_STATUS_PATH=/v1/transactions/{id}

# Como a API autentica: "basic" (Base64 clientId:clientSecret) ou "bearer" (usa o secret puro)
AMPLOPAY_AUTH_MODE=basic

# URL publica do seu site (para o postback/webhook). Em teste local pode deixar vazio.
PUBLIC_URL=

# ---- Produto ----
PRODUCT_PRICE=89.90
