# Copie este arquivo para ".env" e preencha com seus dados reais.
# NUNCA suba o .env para o GitHub.

PORT=3000

# ---- Credenciais AmploPay ----
# Painel AmploPay > Credenciais > "Criar/Consultar transacoes"
AMPLOPAY_CLIENT_ID=
AMPLOPAY_CLIENT_SECRET=

# ---- Endpoints AmploPay ----
# URL base confirmada na doc oficial (Introducao > Requisicoes e URL base).
AMPLOPAY_BASE_URL=https://app.amplopay.com/api/v1
# [PREENCHER] caminhos exatos das rotas "Receber pix", "Receber cartao" e
# "Buscar transacao" — abra cada pagina da doc e confira.
AMPLOPAY_CREATE_PATH=/transactions
AMPLOPAY_CARD_PATH=/transactions
AMPLOPAY_STATUS_PATH=/transactions/{id}

# Como a API autentica: "basic" (Base64 clientId:clientSecret) ou "bearer" (usa o secret puro)
AMPLOPAY_AUTH_MODE=basic

# URL publica do seu site (para o postback/webhook). Em teste local pode deixar vazio.
PUBLIC_URL=

# ---- Produto ----
PRODUCT_PRICE=89.90
