# Copie este arquivo para ".env" e preencha com seus dados reais.
# NUNCA suba o .env para o GitHub.

PORT=3000

# ---- Credenciais AmploPay ----
# Painel AmploPay > Integracoes > API > Gerar credenciais.
# As chaves so aparecem uma vez; guarde num lugar seguro.
AMPLOPAY_PUBLIC_KEY=
AMPLOPAY_SECRET_KEY=

# ---- Endpoints AmploPay (conferidos na doc oficial) ----
AMPLOPAY_BASE_URL=https://app.amplopay.com/api/v1
AMPLOPAY_PIX_PATH=/gateway/pix/receive
AMPLOPAY_STATUS_PATH=/gateway/transactions
# A pagina "Receber cartao" ainda nao foi conferida; ajuste se a rota for outra.
AMPLOPAY_CARD_PATH=/gateway/card/receive

# URL publica do site, usada como callbackUrl das transacoes.
# Em producao: https://casadasofertas.vercel.app
PUBLIC_URL=

# ---- Produto ----
PRODUCT_PRICE=89.90
